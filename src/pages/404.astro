---
import Base from '../layouts/Base.astro';
---

<Base title="Not found">
  <h1 class="display">Not found</h1>
  <p class="muted" style="max-width:68ch;margin-top:8px">
    Nothing lives at this address. If a doc moved, its current version is findable from
    <a href="/archive/">the Archive</a> — press <span class="badge" style="padding:0 6px">/</span> to search.
  </p>
</Base>
