---
interface Props { stage: string }
const { stage } = Astro.props;
const LABELS: Record<string, string> = {
  shortlist: 'Shortlist',
  dm_sent: 'DM sent',
  replied: 'Replied',
  interview: 'Interview',
  offer: 'Offer',
  signed: 'Signed',
  passed: 'Passed',
};
---
<span class={`badge badge--stage-${stage}`}>{LABELS[stage] ?? stage}</span>
