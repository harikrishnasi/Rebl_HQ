---
interface Entry {
  date: string | Date;
  decision: string;
  reason: string;
  category: string;
}
interface Props { entries: Entry[] }
const { entries } = Astro.props;

const fmt = (d: string | Date) =>
  typeof d === 'string' ? d : d.toISOString().slice(0, 10);
---

{entries.length === 0 ? (
  <div class="empty">No decisions logged yet. Write down the next irreversible one.</div>
) : (
  <div>
    {entries.map((e) => (
      <div class="decision" data-category={e.category}>
        <span class="decision-date">{fmt(e.date)}</span>
        <div>
          <div class="decision-text">{e.decision}</div>
          <div class="decision-reason">{e.reason}</div>
        </div>
        <span class="badge">{e.category}</span>
      </div>
    ))}
  </div>
)}
